{
  "expo": {
    "name": "DaniCake",
    "slug": "DaniCake",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/imagens/LogoCake.png",
    "scheme": "danicake",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.DaniCake",
      "usesCleartextTraffic": true,
      "networkSecurityConfig": "./network-security-config.xml"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-router",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "b362ddbc-446f-4154-83d6-1e77e77e4ea9"
      },
      "router": {}
    },
    "owner": "mimi71"
  }
}
